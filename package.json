{
  "name": "wordle-solver",
  "version": "0.1.0",
  "description": "Entropy-based Wordle solver — TypeScript CLI targeting ~3.43 avg guesses.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:feedback": "vitest run test/feedback.test.ts",
    "build-cache": "tsx src/scripts/buildCache.ts",
    "play": "tsx src/index.ts",
    "benchmark": "tsx src/scripts/benchmark.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
